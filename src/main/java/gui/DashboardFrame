    private void addSidebarNavButton(String text, String targetCard, boolean isForm) {
        JButton btn = new JButton(text);
        btn.setMaximumSize(new Dimension(230, 45));
        btn.setBackground(COLOR_SIDEBAR);
        btn.setForeground(new Color(200, 200, 200));
        btn.setFont(new Font("Segoe UI", Font.PLAIN, 14));
        btn.setFocusPainted(false);
        btn.setBorderPainted(false);
        btn.setHorizontalAlignment(SwingConstants.LEFT);
        btn.setBorder(BorderFactory.createEmptyBorder(0, 25, 0, 0));
        btn.setAlignmentX(Component.CENTER_ALIGNMENT);

        btn.addMouseListener(new java.awt.event.MouseAdapter() {
            public void mouseEntered(java.awt.event.MouseEvent evt) {
                btn.setBackground(new Color(46, 58, 71));
                btn.setForeground(COLOR_TEXT_LIGHT);
            }
            public void mouseExited(java.awt.event.MouseEvent evt) {
                btn.setBackground(COLOR_SIDEBAR);
                btn.setForeground(new Color(200, 200, 200));
            }
        });

        btn.addActionListener(e -> {
            if (isForm) {
                jenisTransaksiAktif = targetCard;
                lblFormTitle.setText("FORM " + text.toUpperCase());
                txtNominal.setText("");
                txtPin.setText("");
                cardLayout.show(contentPanel, "PANEL_FORM");
            } else {
                muatDataRiwayatKeTabel();
                cardLayout.show(contentPanel, "PANEL_HISTORY");
            }
        });

        sidebarPanel.add(btn);
        sidebarPanel.add(Box.createVerticalStrut(5));
    }

