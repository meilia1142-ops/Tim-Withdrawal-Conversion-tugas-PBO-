    private JPanel buatPanelHistoryDinamis() {
        JPanel wrapper = new JPanel(new BorderLayout(20, 20));
        wrapper.setBackground(COLOR_BG);
        wrapper.setBorder(BorderFactory.createEmptyBorder(30, 30, 30, 30));

        JLabel lblTitle = new JLabel("RIWAYAT TRANSAKSI NASABAH");
        lblTitle.setFont(new Font("Segoe UI", Font.BOLD, 20));
        lblTitle.setForeground(COLOR_TEXT_DARK);
        wrapper.add(lblTitle, BorderLayout.NORTH);

        String[] columns = {"ID Trx", "ID Nasabah", "Jenis Penarikan", "Nominal", "Status"};
        tableModel = new DefaultTableModel(columns, 0) {
            @Override
            public boolean isCellEditable(int row, int column) {
                return false;
            }
        };

        tblHistory = new JTable(tableModel);
        tblHistory.setFont(new Font("Segoe UI", Font.PLAIN, 14));
        tblHistory.setRowHeight(30);
        tblHistory.getTableHeader().setFont(new Font("Segoe UI", Font.BOLD, 14));
        tblHistory.getTableHeader().setBackground(new Color(230, 235, 242));
        tblHistory.setGridColor(new Color(240, 240, 240));

        JScrollPane scrollPane = new JScrollPane(tblHistory);
        scrollPane.setBorder(BorderFactory.createLineBorder(new Color(220, 225, 230)));
        wrapper.add(scrollPane, BorderLayout.CENTER);

        return wrapper;
    }

    private void muatDataRiwayatKeTabel() {
        try {
            tableModel.setRowCount(0);
            List<TransaksiPenarikan> list = penarikanDAO.findAll();
            if (list != null) {
                for (TransaksiPenarikan trx : list) {
                    tableModel.addRow(new Object[]{
                            trx.getIdPenarikan(),
                            trx.getIdNasabah(),
                            trx.getJenisPenarikan(),
                            "Rp " + trx.getNominal(),
                            trx.getStatus()
                    });
                }
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    private void eksekusiTransaksiDinamis() {
        try {
            if (txtNominal.getText().trim().isEmpty() || txtPin.getPassword().length == 0) {
                JOptionPane.showMessageDialog(this, "Semua kolom input wajib diisi!");
                return;
            }

            BigDecimal nominal = new BigDecimal(txtNominal.getText());
            String pin = new String(txtPin.getPassword());

            switch (jenisTransaksiAktif) {
                case "TUNAI" -> {
                    boolean result = service.tarikTunai(nominal, pin);
                    JOptionPane.showMessageDialog(this, result ? "Penarikan Tunai Berhasil!" : "Penarikan Tunai Gagal");
                }
                case "PULSA" -> {
                    boolean result = service.konversiPulsa(nominal, pin);
                    JOptionPane.showMessageDialog(this, result ? "Konversi Pulsa Sukses!" : "Konversi Pulsa Gagal");
                }
                case "TOKEN" -> {
                    String kode = service.konversiToken(nominal, pin);
                    if (kode != null) {
                        JOptionPane.showMessageDialog(this, "Konversi Token Berhasil!\nKode Token Anda: " + kode);
                    } else {
                        JOptionPane.showMessageDialog(this, "Konversi Token Gagal");
                    }
                }
                case "SEMBAKO" -> {
                    boolean result = service.konversiSembako(nominal, pin);
                    JOptionPane.showMessageDialog(this, result ? "Konversi Sembako Berhasil!" : "Konversi Sembako Gagal");
                }
                case "BANK" -> {
                    String namaBank = JOptionPane.showInputDialog(this, "Masukkan Nama Bank (e.g., BCA, BNI, BRI):");
                    String noRek = JOptionPane.showInputDialog(this, "Masukkan Nomor Rekening Tujuan:");
                    if (namaBank == null || noRek == null || namaBank.trim().isEmpty() || noRek.trim().isEmpty()) {
                        JOptionPane.showMessageDialog(this, "Transaksi Dibatalkan. Data Bank tidak lengkap.");
                        return;
                    }
                    boolean result = service.tarikViaBank(nominal, pin, namaBank, noRek);
                    JOptionPane.showMessageDialog(this, result ? "Transfer ke Bank " + namaBank + " Berhasil!" : "Transfer Bank Gagal");
                }
                case "E_WALLET" -> {
                    String namaWallet = JOptionPane.showInputDialog(this, "Masukkan Jenis E-Wallet (e.g., DANA, OVO, GOPAY):");
                    String noHp = JOptionPane.showInputDialog(this, "Masukkan Nomor Handphone:");
                    if (namaWallet == null || noHp == null || namaWallet.trim().isEmpty() || noHp.trim().isEmpty()) {
                        JOptionPane.showMessageDialog(this, "Transaksi Dibatalkan. Data E-Wallet tidak lengkap.");
                        return;
                    }
                    boolean result = service.tarikViaEWallet(nominal, pin, namaWallet, noHp);
                    JOptionPane.showMessageDialog(this, result ? "Top-Up " + namaWallet + " Berhasil!" : "Top-Up E-Wallet Gagal");
                }
            }

            txtNominal.setText("");
            txtPin.setText("");

        } catch (NumberFormatException ex) {
            JOptionPane.showMessageDialog(this, "Input nominal harus berupa angka data numerik valid!");
        } catch (Exception ex) {
            ex.printStackTrace();
            JOptionPane.showMessageDialog(this, ex.getMessage());
        }
    }
