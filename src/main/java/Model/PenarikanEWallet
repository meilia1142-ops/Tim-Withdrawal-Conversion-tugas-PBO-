package model;

import java.math.BigDecimal;

public class PenarikanEWallet extends Penarikan {

    private String namaWallet;
    private String noHp;

    public PenarikanEWallet(int idNasabah, BigDecimal nominal, String namaWallet, String noHp) {
        super(idNasabah, nominal);
        this.namaWallet = namaWallet;
        this.noHp = noHp;
    }

    @Override
    public void eksekusiPenarikan() {
        System.out.println("Top-Up E-Wallet " + namaWallet + " ke " + noHp + ": " + nominal);
    }

    public String getNamaWallet() {
        return namaWallet;
    }

    public void setNamaWallet(String namaWallet) {
        this.namaWallet = namaWallet;
    }

    public String getNoHp() {
        return noHp;
    }

    public void setNoHp(String noHp) {
        this.noHp = noHp;
    }
}
