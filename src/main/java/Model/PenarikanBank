package model;

import java.math.BigDecimal;

public class PenarikanBank extends Penarikan {

    private String namaBank;
    private String noRekening;

    public PenarikanBank(int idNasabah, BigDecimal nominal, String namaBank, String noRekening) {
        super(idNasabah, nominal);
        this.namaBank = namaBank;
        this.noRekening = noRekening;
    }

    @Override
    public void eksekusiPenarikan() {
        System.out.println("Transfer Bank " + namaBank + " ke " + noRekening + ": " + nominal);
    }

    public String getNamaBank() {
        return namaBank;
    }

    public void setNamaBank(String namaBank) {
        this.namaBank = namaBank;
    }

    public String getNoRekening() {
        return noRekening;
    }

    public void setNoRekening(String noRekening) {
        this.noRekening = noRekening;
    }
}
