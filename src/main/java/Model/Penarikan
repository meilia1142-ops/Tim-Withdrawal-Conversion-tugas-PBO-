package model;

import java.math.BigDecimal;

public abstract class Penarikan {

    protected int idNasabah;
    protected BigDecimal nominal;

    public Penarikan(int idNasabah,
                     BigDecimal nominal) {

        this.idNasabah = idNasabah;
        this.nominal = nominal;
    }

    public Penarikan() {

    }

    public abstract void eksekusiPenarikan();
}
