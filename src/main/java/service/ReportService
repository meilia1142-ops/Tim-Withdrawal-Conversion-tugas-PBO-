package service;

import dao.PenarikanDAO;
import model.TransaksiPenarikan;

import java.math.BigDecimal;
import java.util.List;

public class ReportService {

    private final PenarikanDAO dao =
            new PenarikanDAO();

    public BigDecimal totalPenarikan(
            int idNasabah
    ) {

        List<TransaksiPenarikan> data =
                dao.findByNasabahId(
                        idNasabah
                );

        BigDecimal total =
                BigDecimal.ZERO;

        for (
                TransaksiPenarikan trx
                : data
        ) {

            total =
                    total.add(
                            trx.getNominal()
                    );
        }

        return total;
    }
}
